page {
  --bg: #f5f5f5;
  --surface: #ffffff;
  --fg: #2d2d2d;
  --muted: #888888;
  --border: #e5e5e5;
  --accent: #4A90D9;
  --accent-light: rgba(74, 144, 217, 0.08);

  background: var(--bg);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  color: var(--fg);
  font-size: 28rpx;
  -webkit-font-smoothing: antialiased;
}
