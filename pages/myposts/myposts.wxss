/* 我的发布 */
.feed { padding: 24rpx 32rpx; display: flex; flex-direction: column; gap: 20rpx; }
.feed-card {
  background: var(--surface); border-radius: 24rpx;
  padding: 28rpx 32rpx; border: 1rpx solid var(--border);
}
.card-top { display: flex; align-items: flex-start; gap: 20rpx; }
.card-avatar {
  width: 80rpx; height: 80rpx; border-radius: 50%; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  font-size: 30rpx; font-weight: 600; color: #fff;
}
.card-body { flex: 1; min-width: 0; }
.card-title {
  font-size: 30rpx; font-weight: 600; line-height: 1.35;
  margin-bottom: 8rpx;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
  overflow: hidden;
}
.card-meta { font-size: 24rpx; color: var(--muted); display: flex; align-items: center; gap: 16rpx; flex-wrap: wrap; }
.card-tag {
  font-size: 20rpx; font-weight: 600; padding: 4rpx 16rpx;
  border-radius: 20rpx; background: var(--accent-light); color: var(--accent);
}
.card-bottom {
  display: flex; justify-content: space-between; align-items: center;
  margin-top: 20rpx; padding-top: 20rpx; border-top: 1rpx solid var(--border);
}
.card-reward { font-size: 32rpx; font-weight: 700; color: #E07B4A; }
.post-status {
  font-size: 22rpx; font-weight: 600; padding: 4rpx 16rpx; border-radius: 20rpx;
}
.post-status.done { background: rgba(74, 180, 74, 0.12); color: #4AB44A; }
.post-status.pending { background: rgba(224, 155, 74, 0.12); color: #E09B4A; }
.post-delete {
  font-size: 24rpx; font-weight: 500; color: #E05050; padding: 10rpx 24rpx;
  border-radius: 28rpx; border: 1rpx solid rgba(224, 80, 80, 0.2);
}
.placeholder { display: flex; flex-direction: column; align-items: center; padding: 200rpx 40rpx; }
.placeholder-icon { font-size: 80rpx; margin-bottom: 32rpx; opacity: 0.4; }
.placeholder-text { font-size: 30rpx; color: var(--muted); }
