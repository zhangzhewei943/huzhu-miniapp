.page {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background: var(--bg);
  padding: 40rpx;
}
.login-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  max-width: 600rpx;
}
.logo { font-size: 100rpx; margin-bottom: 24rpx; }
.app-name { font-size: 44rpx; font-weight: 700; margin-bottom: 12rpx; color: var(--fg); }
.app-desc { font-size: 28rpx; color: var(--muted); margin-bottom: 80rpx; text-align: center; }

.btn-wx-login {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #07C160;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 12rpx;
  border: none;
  text-align: center;
  padding: 0;
}
.btn-wx-login:active { opacity: 0.85; }

.hint {
  margin-top: 32rpx;
  font-size: 24rpx;
  color: var(--muted);
}
