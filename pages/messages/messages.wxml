<!-- 消息页 -->
<view class="page">
  <!-- 子标签 -->
  <view class="msg-tabs">
    <view
      wx:for="{{tabs}}"
      wx:key="key"
      class="msg-tab {{activeTab === item.key ? 'active' : ''}}"
      data-key="{{item.key}}"
      bindtap="switchTab"
    >{{item.label}}</view>
  </view>

  <!-- 接单列表 -->
  <block wx:if="{{activeTab === 'accepted'}}">
    <view class="feed" wx:if="{{acceptedList.length > 0}}">
      <view wx:for="{{acceptedList}}" wx:key="id" class="feed-card">
        <view class="card-top">
          <view class="card-avatar" style="background: {{item.userColor}};">{{item.user[0]}}</view>
          <view class="card-body">
            <view class="card-title">{{item.title}}</view>
            <view class="card-meta">
              <text>{{item.user}}</text>
              <text>{{item.location}}</text>
              <text class="card-tag">{{item.tag}}</text>
            </view>
          </view>
        </view>
        <view class="card-bottom">
          <view class="card-reward">{{item.reward > 0 ? '¥' + item.reward : '无偿'}}</view>
          <view class="card-action" catchtap="copyWechat" data-id="{{item.id}}">复制微信</view>
        </view>
      </view>
    </view>
    <view class="placeholder" wx:else>
      <text class="placeholder-icon">💬</text>
      <text class="placeholder-text">暂无接单记录</text>
    </view>
  </block>

  <!-- 发布列表 -->
  <block wx:if="{{activeTab === 'published'}}">
    <view class="feed" wx:if="{{publishedList.length > 0}}">
      <view wx:for="{{publishedList}}" wx:key="id" class="feed-card">
        <view class="card-top">
          <view class="card-avatar" style="background: #4A90D9;">我</view>
          <view class="card-body">
            <view class="card-title">{{item.title}}</view>
            <view class="card-meta">
              <text>{{item.location}}</text>
              <text>{{item.time}}</text>
              <text class="card-tag">{{item.tag}}</text>
              <text class="post-status {{item.status === 'done' ? 'done' : 'pending'}}">{{item.status === 'done' ? '已接单' : '未完成'}}</text>
            </view>
          </view>
        </view>
        <view class="card-bottom">
          <view class="card-reward">{{item.reward > 0 ? '¥' + item.reward : '无偿'}}</view>
          <view class="card-action" wx:if="{{item.status === 'done'}}" catchtap="copyWechat" data-id="{{item.id}}">复制微信</view>
          <view class="post-delete" wx:else catchtap="deletePost" data-id="{{item.id}}">删除</view>
        </view>
      </view>
    </view>
    <view class="placeholder" wx:else>
      <text class="placeholder-icon">📋</text>
      <text class="placeholder-text">暂无发布记录</text>
    </view>
  </block>
</view>
