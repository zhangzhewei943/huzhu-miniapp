/* 首页样式 */

/* Banner */
.banner { height: 320rpx; margin: 20rpx 24rpx 24rpx; border-radius: 24rpx; overflow: hidden; }
.banner-slide { height: 100%; }
.banner-img { width: 100%; height: 100%; }
.banner-placeholder {
  width: 100%; height: 100%; display: flex; flex-direction: column;
  justify-content: center; padding: 40rpx;
}
.banner-ptag {
  font-size: 22rpx; font-weight: 600; background: rgba(255,255,255,0.2);
  padding: 4rpx 16rpx; border-radius: 6rpx; margin-bottom: 14rpx; align-self: flex-start;
  color: #fff; letter-spacing: 0.04em;
}
.banner-ptitle { font-size: 40rpx; font-weight: 700; color: #fff; line-height: 1.3; margin-bottom: 10rpx; }
.banner-psub { font-size: 24rpx; color: rgba(255,255,255,0.8); }

/* 筛选标签 */
.filter-scroll { width: 100%; white-space: nowrap; padding-bottom: 20rpx; }
.filter-tabs { display: flex; gap: 16rpx; padding: 0 24rpx; }
.filter-tab {
  flex-shrink: 0; padding: 14rpx 32rpx; border-radius: 36rpx;
  font-size: 26rpx; font-weight: 500; color: var(--muted);
  background: var(--surface); border: 1rpx solid var(--border);
  transition: all 0.15s;
}
.filter-tab.active { background: var(--accent); border-color: var(--accent); color: #fff; font-weight: 600; }

/* 区块标题 */
.sec-header { display: flex; justify-content: space-between; align-items: center; padding: 0 24rpx; margin-bottom: 20rpx; }
.sec-title { font-size: 32rpx; font-weight: 600; color: var(--fg); }
.sec-more { font-size: 26rpx; color: var(--muted); }

/* 卡片列表 */
.feed { padding: 0 24rpx; display: flex; flex-direction: column; gap: 20rpx; padding-bottom: 24rpx; }
.feed-card {
  background: var(--surface); border-radius: 24rpx;
  padding: 28rpx 32rpx; border: 1rpx solid var(--border);
}
.feed-card:active { transform: scale(0.985); }

.card-top { display: flex; align-items: flex-start; }
.card-body { flex: 1; min-width: 0; }
.card-title {
  font-size: 30rpx; font-weight: 600; line-height: 1.35;
  margin-bottom: 8rpx;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
  overflow: hidden;
}
.card-meta { font-size: 24rpx; color: var(--muted); display: flex; align-items: center; gap: 16rpx; flex-wrap: wrap; }
.card-tag {
  font-size: 20rpx; font-weight: 600; padding: 4rpx 16rpx;
  border-radius: 20rpx; background: var(--accent-light); color: var(--accent);
}

.card-bottom {
  display: flex; justify-content: space-between; align-items: center;
  margin-top: 20rpx; padding-top: 20rpx; border-top: 1rpx solid var(--border);
}
.card-reward { font-size: 32rpx; font-weight: 700; color: #E07B4A; }
.card-action {
  font-size: 24rpx; font-weight: 600; color: var(--accent);
  padding: 10rpx 28rpx; border-radius: 32rpx; background: var(--accent-light);
}

/* 占位 */
.placeholder { display: flex; justify-content: center; padding: 80rpx 40rpx; }
.placeholder-text { font-size: 30rpx; color: var(--muted); }

/* 页面布局 */
.page { display: flex; flex-direction: column; height: 100vh; overflow: visible; }
.top-area { flex-shrink: 0; }
.feed-scroll { flex: 1; overflow: hidden; }

/* 排序浮层 */
.sort-overlay {
  position: fixed; top: 0; right: 0; bottom: 0; left: 0;
  background: rgba(0,0,0,0.3); z-index: 100;
  display: flex; align-items: flex-end; justify-content: center;
  opacity: 0; pointer-events: none; transition: opacity 0.25s;
}
.sort-overlay.show { opacity: 1; pointer-events: auto; }
.sort-sheet {
  width: 100%; background: var(--surface);
  border-radius: 32rpx 32rpx 0 0; padding: 16rpx 0 0;
  transform: translateY(100%); transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
}
.sort-overlay.show .sort-sheet { transform: translateY(0); }
.sort-sheet-title { font-size: 26rpx; color: var(--muted); text-align: center; padding: 20rpx 0 28rpx; }
.sort-option {
  display: flex; align-items: center; justify-content: space-between;
  padding: 28rpx 48rpx; font-size: 32rpx;
}
.sort-option:last-child { padding-bottom: 48rpx; }
.sort-option .check { color: var(--accent); font-size: 32rpx; visibility: hidden; }
.sort-option.selected .check { visibility: visible; }
