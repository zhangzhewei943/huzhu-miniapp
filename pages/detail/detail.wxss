/* 任务详情页 */
.detail-hero {
  background: linear-gradient(180deg, var(--accent-light), var(--bg));
  padding: 40rpx 32rpx 48rpx;
}
.detail-status { font-size: 24rpx; font-weight: 600; color: var(--accent); margin-bottom: 16rpx; }
.detail-title { font-size: 44rpx; font-weight: 700; line-height: 1.3; }
.detail-reward { font-size: 56rpx; font-weight: 700; color: #E07B4A; margin-top: 20rpx; }
.detail-reward .unit { font-size: 28rpx; font-weight: 500; }
.free-label { font-size: 32rpx; color: var(--accent); }

.detail-section { padding: 32rpx; border-bottom: 1rpx solid var(--border); }
.section-label { font-size: 26rpx; color: var(--muted); font-weight: 500; margin-bottom: 16rpx; }
.section-text { font-size: 30rpx; line-height: 1.7; }
.section-text.muted { font-size: 26rpx; color: var(--muted); }

.detail-publisher { display: flex; align-items: center; gap: 24rpx; padding: 32rpx; }
.pub-avatar {
  width: 96rpx; height: 96rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 36rpx; font-weight: 600; color: #fff; flex-shrink: 0;
}
.pub-info { flex: 1; }
.pub-name { font-size: 30rpx; font-weight: 600; margin-bottom: 4rpx; }
.pub-meta { font-size: 24rpx; color: var(--muted); }
.pub-badge {
  font-size: 22rpx; color: var(--accent); background: var(--accent-light);
  padding: 6rpx 20rpx; border-radius: 20rpx; font-weight: 500;
}

.detail-cta { padding: 24rpx 32rpx 40rpx; }
.btn-primary {
  width: 100%; padding: 24rpx; border-radius: 16rpx;
  background: var(--accent); color: #fff; font-size: 32rpx; font-weight: 600;
  border: none; line-height: 1.5;
}
.btn-primary:active { opacity: 0.85; }

.loading { display: flex; justify-content: center; padding: 200rpx 40rpx; color: var(--muted); }
