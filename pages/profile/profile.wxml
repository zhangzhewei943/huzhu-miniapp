<!-- 个人中心 -->
<view class="page">
  <!-- 头像 + 名称 -->
  <view class="profile-header">
    <view class="profile-avatar">{{profileData.name[0]}}</view>
    <view class="profile-name">
      <block wx:if="{{!editing}}">{{profileData.name}}</block>
      <input wx:else class="name-input" value="{{editName}}" bindinput="onNameInput" maxlength="12" focus="{{editing}}" />
    </view>
    <view class="profile-id">ID: {{profileData.studentId}}</view>
  </view>

  <!-- 统计数据 -->
  <view class="profile-stats">
    <view class="stat-item">
      <text class="stat-num">{{myPosts.length}}</text>
      <text class="stat-label">已发布</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{acceptedCount}}</text>
      <text class="stat-label">已接单</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">12</text>
      <text class="stat-label">已完成</text>
    </view>
  </view>

  <!-- 个人信息 -->
  <view class="profile-section-title">个人信息</view>
  <view class="profile-info-card">
    <view wx:for="{{fields}}" wx:key="key" class="profile-info-row {{editing && !item.readonly ? 'editing' : ''}}">
      <text class="info-label">{{item.label}}</text>
      <text class="info-value" wx:if="{{!editing || item.readonly}}">{{editData[item.key] || profileData[item.key]}}</text>
      <picker wx:if="{{editing && !item.readonly && item.type === 'select'}}" mode="selector" range="{{item.options}}" data-key="{{item.key}}" bindchange="onFieldChange">
        <view class="info-input">{{editData[item.key] || profileData[item.key]}}</view>
      </picker>
      <input wx:if="{{editing && !item.readonly && item.type === 'text'}}" class="info-input" value="{{editData[item.key] || profileData[item.key]}}" data-key="{{item.key}}" bindinput="onFieldInput" />
    </view>
  </view>

  <!-- 编辑 / 保存按钮 -->
  <view class="profile-actions">
    <block wx:if="{{editing}}">
      <button class="btn-cancel" bindtap="cancelEdit">取消</button>
      <button class="btn-save" bindtap="saveProfile">保存</button>
    </block>
    <button wx:else class="btn-edit" bindtap="startEdit">编辑资料</button>
  </view>

  <!-- 菜单 -->
  <view class="profile-menu">
    <view class="menu-item" bindtap="goMyPosts">
      <text>我的发布</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item">
      <text>帮助中心</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item">
      <text>设置</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>
