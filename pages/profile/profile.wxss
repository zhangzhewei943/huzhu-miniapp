/* 个人中心 */
.profile-header {
  display: flex; flex-direction: column; align-items: center;
  padding: 56rpx 32rpx 40rpx;
}
.profile-avatar {
  width: 144rpx; height: 144rpx; border-radius: 50%;
  background: var(--accent); color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: 56rpx; font-weight: 700; margin-bottom: 24rpx;
}
.profile-name { font-size: 40rpx; font-weight: 700; margin-bottom: 4rpx; }
.name-input {
  font-size: 40rpx; font-weight: 700; border-bottom: 4rpx solid var(--accent);
  text-align: center; width: 280rpx;
}
.profile-id { font-size: 26rpx; color: var(--muted); }

/* 统计 */
.profile-stats { display: flex; justify-content: center; gap: 64rpx; padding: 0 32rpx 40rpx; }
.stat-item { display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
.stat-num { font-size: 44rpx; font-weight: 700; }
.stat-label { font-size: 24rpx; color: var(--muted); }

/* 信息卡片 */
.profile-section-title { font-size: 26rpx; font-weight: 600; color: var(--muted); padding: 0 32rpx 16rpx; }
.profile-info-card {
  margin: 0 32rpx; background: var(--surface);
  border-radius: 24rpx; border: 1rpx solid var(--border); overflow: hidden;
}
.profile-info-row {
  display: flex; align-items: center; padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--border);
}
.profile-info-row:last-child { border-bottom: none; }
.info-label { font-size: 28rpx; color: var(--muted); width: 144rpx; flex-shrink: 0; }
.info-value { font-size: 28rpx; color: var(--fg); flex: 1; }
.info-input {
  font-size: 28rpx; color: var(--fg); flex: 1;
  border: 1rpx solid var(--border); border-radius: 12rpx; padding: 12rpx 20rpx;
  background: var(--bg);
}

/* 按钮 */
.profile-actions { display: flex; gap: 24rpx; padding: 32rpx; }
.btn-edit {
  flex: 1; padding: 20rpx; border-radius: 16rpx;
  font-size: 30rpx; font-weight: 600; color: var(--accent);
  border: 1rpx solid var(--accent); background: none;
}
.btn-edit:active { background: var(--accent-light); }
.btn-save {
  flex: 1; padding: 20rpx; border-radius: 16rpx;
  font-size: 30rpx; font-weight: 600; color: #fff;
  background: var(--accent); border: none;
}
.btn-save:active { opacity: 0.85; }
.btn-cancel {
  flex: 1; padding: 20rpx; border-radius: 16rpx;
  font-size: 30rpx; font-weight: 600; color: var(--muted);
  border: 1rpx solid var(--border); background: var(--surface);
}

/* 菜单 */
.profile-menu {
  margin: 16rpx 32rpx; background: var(--surface);
  border-radius: 24rpx; border: 1rpx solid var(--border); overflow: hidden;
}
.menu-item {
  display: flex; justify-content: space-between; align-items: center;
  padding: 32rpx; border-bottom: 1rpx solid var(--border);
  font-size: 28rpx;
}
.menu-item:last-child { border-bottom: none; }
.menu-arrow { color: var(--muted); font-size: 36rpx; }
